{
  "collection_name": "workflows",
  "fields": {
    "workflow_id": {"type": "keyword", "required": true},
    "task_type": {"type": "keyword", "required": true},
    "description": {"type": "text", "required": true},
    "steps": {"type": "array", "items": {"type": "string"}, "required": true},
    "tool_order": {"type": "array", "items": {"type": "string"}, "required": true},
    "success_rate": {"type": "float", "required": true, "default": 0.0},
    "avg_score": {"type": "float", "required": true, "default": 0.0},
    "usage_count": {"type": "integer", "required": true, "default": 0},
    "version": {"type": "integer", "required": true, "default": 1},
    "status": {"type": "keyword", "required": true, "default": "active"},
    "source_skill_id": {"type": "keyword", "required": false},
    "created_at": {"type": "date", "required": true},
    "updated_at": {"type": "date", "required": true}
  },
  "embedding_fields": ["task_type", "description", "steps", "tool_order"]
}
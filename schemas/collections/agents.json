{
  "name": "agents",
  "description": "存储系统中的所有 agent 信息",
  "payload_schema": {
    "agent_id": {"type": "keyword"},
    "role": {"type": "keyword"},
    "skills": {"type": "keyword", "array": true},
    "success_rate": {"type": "float"},
    "current_load": {"type": "integer"},
    "created_at": {"type": "datetime"}
  },
  "embedding_fields": ["role", "skills"],
  "vector_config": {
    "size": 1536,
    "distance": "Cosine"
  }
}